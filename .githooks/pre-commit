#!/usr/bin/env bash
# Pre-commit hook: block imports from EdgeSync/ or libfossil/ internal/ subtrees.
# Activate: run `git config core.hooksPath .githooks` from the repo root.
# This keeps agent-infra honest about the public API boundary documented in README §Development setup.

set -euo pipefail

# Module paths — mirrored from reference/EdgeSync/go.mod and reference/libfossil/go.mod.
# If either upstream renames its module, update these constants.
EDGESYNC_MODULE="github.com/dmestas/edgesync"
LIBFOSSIL_MODULE="github.com/danmestas/libfossil"

# Collect staged .go files (Added, Copied, Modified, Renamed). Null-delimited for safety.
mapfile -d '' staged < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.go' || true)

if [ "${#staged[@]}" -eq 0 ]; then
  exit 0
fi

violations=0

for file in "${staged[@]}"; do
  # Skip files that were staged-deleted or vanished between diff and grep.
  [ -f "$file" ] || continue

  # Match import lines referencing <module>/internal/... — handles both
  # single-line `import "..."` and block-form `"..."` entries.
  # Double-quoted strings containing "<module>/internal" are the signal.
  while IFS=: read -r lineno content; do
    # lineno is empty when grep finds nothing — skip.
    [ -n "$lineno" ] || continue
    printf 'forbidden import: %s:%s: %s\n' "$file" "$lineno" "${content## }" >&2
    violations=$((violations + 1))
  done < <(
    grep -nE "\"(${EDGESYNC_MODULE//\//\\/}|${LIBFOSSIL_MODULE//\//\\/})/internal(/|\")" "$file" 2>/dev/null || true
  )
done

if [ "$violations" -gt 0 ]; then
  echo "" >&2
  echo "agent-infra pre-commit: $violations forbidden import(s) detected." >&2
  echo "agent-infra must consume only the public API of EdgeSync and libfossil." >&2
  echo "See README §Development setup." >&2
  exit 1
fi

# --- TigerStyle checks (issue 2t0) ---------------------------------------
# The import-boundary guard above is a correctness gate. The checks below are
# discipline gates: formatting drift and stray TODO markers. They run only on
# staged .go files so the hook stays fast.

fmt_violations=0
todo_violations=0

for file in "${staged[@]}"; do
  [ -f "$file" ] || continue

  # gofmt check: -l prints a filename only when formatting would change it.
  if [ -n "$(gofmt -l "$file" 2>/dev/null)" ]; then
    printf 'gofmt drift: %s\n' "$file" >&2
    fmt_violations=$((fmt_violations + 1))
  fi

  # TODO check: production code only. Test files may document pending
  # behavior inline; everything else must be tracked as an ADR or roadmap note.
  case "$file" in
    *_test.go) : ;;  # exempt
    *)
      while IFS=: read -r lineno content; do
        [ -n "$lineno" ] || continue
        printf 'TODO marker: %s:%s: %s\n' "$file" "$lineno" "${content## }" >&2
        todo_violations=$((todo_violations + 1))
      done < <(grep -nE 'TODO' "$file" 2>/dev/null || true)
      ;;
  esac
done

if [ "$fmt_violations" -gt 0 ]; then
  echo "" >&2
  echo "agent-infra pre-commit: $fmt_violations file(s) need gofmt." >&2
  echo "Run: gofmt -w <files>   (or: make fmt)" >&2
fi

if [ "$todo_violations" -gt 0 ]; then
  echo "" >&2
  echo "agent-infra pre-commit: $todo_violations TODO marker(s) in production code." >&2
  echo "File an ADR or a note under docs/ instead." >&2
  echo "See project CLAUDE.md §Task tracking." >&2
fi

if [ "$fmt_violations" -gt 0 ] || [ "$todo_violations" -gt 0 ]; then
  exit 1
fi

exit 0
